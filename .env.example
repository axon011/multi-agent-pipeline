# --- Option A: Claude Code (recommended if you have Claude Max) ---
# Routes Planner/Researcher/Writer through the Claude Code CLI via subprocess —
# no API key, uses your Max subscription. Run `claude login` once.
LLM_BACKEND=claude
LOG_LEVEL=INFO

# --- Option B: Z.AI / GLM (per-call billing) ---
# LLM_BACKEND=glm
# LLM_API_KEY=your-zhipu-api-key
# LLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
# LLM_MODEL=glm-5-turbo

# --- Observability (Langfuse) ---
# Optional. When both keys are set, every agent + LLM call is traced
# with cost, latency, and quality data. Without keys the helpers
# silently no-op so the pipeline still runs.
# Sign up at https://cloud.langfuse.com or self-host.
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com
# LANGFUSE_ENVIRONMENT=dev
# LANGFUSE_RELEASE=multi-agent-pipeline@dev

# --- CrewAI ---
# Silence CrewAI's outbound telemetry (it pings telemetry.crewai.com unless told not to).
CREWAI_TRACING_ENABLED=false
